# --- Proveedores (swappables). Default "fake" = corre SIN keys. ---
TRANSCRIPTION_PROVIDER=fake
LLM_PROVIDER=fake

# --- API keys (vacías => modo fake). Pega las reales para activar. ---
ASSEMBLYAI_API_KEY=
ANTHROPIC_API_KEY=

# --- LLM ---
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.2

# --- Marcos pedagógicos activos (csv, en orden) ---
ACTIVE_FRAMEWORKS=minedu_mbdd,oecd_talis

# --- Métricas ---
SILENCE_THRESHOLD=8.0
# FILLER_WORDS acepta csv. Si se omite usa el default del código.
# FILLER_WORDS=o sea,este,¿no?,eh,mmm,digamos,entonces,ya,bueno

# --- Infra ---
DATABASE_URL=sqlite:///./app.db
CORS_ORIGINS=*
